# ─────────────────────────────────────────────
# REQUIRED – app sẽ crash nếu thiếu các biến này
# ─────────────────────────────────────────────

# Đường dẫn file SQLite database (bên trong container)
BIDV_DB_PATH=/app/data/bidv.db

# Đường dẫn file CSV dữ liệu khách hàng (bên trong container)
CUSTOMER_PROFILE_DATA=/app/data/customer_profile.csv

# Đường dẫn file CSV đại diện pháp lý (bên trong container)
LEGAL_REPRESENTATIVE_DATA=/app/data/legal_representative.csv

# ─────────────────────────────────────────────
# GOOGLE CLOUD CREDENTIALS (bắt buộc cho Gemini AI + Document AI)
# ─────────────────────────────────────────────

# Gemini API Key – lấy tại https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# GCP Project ID (dùng cho Document AI)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# File service account JSON – đặt tại y3a/secrets/gcp-service-account.json
# Tạo service account tại https://console.cloud.google.com/iam-admin/serviceaccounts
# Cấp quyền: Document AI API User, Cloud Vision API User

# ─────────────────────────────────────────────
# OPTIONAL – có giá trị mặc định nếu không khai báo
# ─────────────────────────────────────────────

# URL base của ứng dụng (dùng trong email link)
BASE_URL=http://localhost:8501

# Gmail gửi email thông báo
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password

# ─────────────────────────────────────────────
# INTERNAL SERVICES (tự động qua Docker network)
# ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_ENDPOINT=http://mlflow_serve:8080/invocations

# ─────────────────────────────────────────────
# MICROSERVICES URLs (tự động qua Docker network)
# ─────────────────────────────────────────────
OCR_SERVICE_URL=http://ocr_service:8001
NOTIFICATION_SERVICE_URL=http://notification_service:8002

# Document AI Processor ID (lấy tại Google Cloud Console > Document AI)
DOCUMENT_AI_PROCESSOR_ID=your_processor_id_here
